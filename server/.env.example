# Copy to .env and fill in for your local SQL Server instance.
PORT=4000
CORS_ORIGIN=http://localhost:8080

# --- SQL Server connection ---
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=CostPro

# SQL login (leave DB_USER blank to use Windows Authentication via msnodesqlv8)
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd

# Set to true for self-signed certs (local dev) or named instances
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Optional: named instance (e.g. SQLEXPRESS). Leave blank if using DB_PORT.
DB_INSTANCE=

# =====================================================================
# Frontend (.env.local in project root, NOT here) needs these too:
#   VITE_API_URL=http://localhost:4000/api
#   VITE_AZURE_CLIENT_ID=<Application (client) ID from Azure portal>
#   VITE_AZURE_TENANT_ID=<Directory (tenant) ID, or "common">
# =====================================================================